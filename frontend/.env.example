# Clerk (https://dashboard.clerk.com/last-active?path=api-keys)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Dedicated sign-in / sign-up routes (see app/sign-in, app/sign-up)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Where Clerk sends users after a successful sign-in / sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/dashboard

# Supabase PostgreSQL (dashboard → Connect → ORM tab)
# Pooled (PgBouncer, transaction mode, port 6543) — used by the app at runtime,
# via the driver adapter in lib/db.ts. Required to stay pooled: this app runs
# on serverless/edge functions that would otherwise exhaust Postgres' direct
# connection limit.
DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct (non-pooled, port 5432) — required by Prisma's migration engine
# (prisma.config.ts); PgBouncer's transaction pooler doesn't reliably support
# the DDL Prisma Migrate issues.
DIRECT_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Stripe (https://dashboard.stripe.com/test/apikeys) — pricing page checkout
# IMPORTANT: use TEST MODE keys (sk_test_..., whsec_..., pk_test_...) for local/dev.
# Never commit live/secret keys — this file only documents the shape of the values.
#
# Secret key — server-side only, used to create Checkout Sessions.
STRIPE_SECRET_KEY=sk_test_...
#
# Webhook signing secret (https://dashboard.stripe.com/test/webhooks) — verifies the
# stripe-signature header on incoming webhook events. Generated per endpoint (or via
# `stripe listen` for local dev with the Stripe CLI).
STRIPE_WEBHOOK_SECRET=whsec_...
#
# Publishable key (https://dashboard.stripe.com/test/apikeys) — safe to expose
# client-side. Not yet consumed by app code (Checkout redirects server-side, no
# Stripe.js on the client), but validated now for when Stripe.js/Elements is added.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
#
# Price IDs (https://dashboard.stripe.com/test/products) — one per plan, from the
# test-mode Product catalog.
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_ENTERPRISE=price_...

# Google Gemini (https://aistudio.google.com/apikey) — powers the AI income-narrative feature
# (lib/ai.ts, lib/ai/income-narrative.ts). Server-side only, never exposed client-side.
# IMPORTANT: generate this key from a Google Cloud/AI Studio project that has billing DISABLED to
# stay on the free tier — once billing is enabled on that project, every call becomes billable.
GEMINI_API_KEY=...
