// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Prisma 7 removed `url`/`directUrl` from the schema file — connection URLs now
  // live in prisma.config.ts (for the CLI/migration engine) and are passed directly
  // to the driver adapter in lib/db.ts (for the app's runtime client). See:
  // https://pris.ly/d/config-datasource
}

model User {
  id        String    @id @default(cuid())
  clerkId   String    @unique
  email     String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  subscription        Subscription?
  platformConnections PlatformConnection[]
  incomeNarrative     IncomeNarrative?
  reportJobs          ReportJob[]

  @@index([clerkId])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus @default(INCOMPLETE)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([stripeCustomerId])
}

enum SubscriptionStatus {
  INCOMPLETE
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  TRIALING
}

// A signed-in user's connection to one mocked income platform (see
// components/landing/platform-data.ts, the source of truth for valid slugs and each platform's
// demo verifiedAmount). One row per connected platform per user — reconnecting the same platform
// upserts this row rather than creating a duplicate.
model PlatformConnection {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug           String
  verifiedAmount Decimal  @db.Decimal(10, 2)
  connectedAt    DateTime @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @db.Timestamptz(3)

  @@unique([userId, slug])
}

// Cached AI-generated (Gemini) descriptive summary of a user's verified income — see
// lib/ai/income-narrative.ts. One row per user. Regenerated when `inputHash` (a hash of the
// user's current per-platform verifiedAmounts) no longer matches the latest connection state, or
// when `generatedAt` is older than the service's staleness window — whichever comes first. This
// exists purely so the dashboard card and the PDF report don't call Gemini on every single page
// load/report download; it is never treated as a source of truth for verifiedAmount itself.
model IncomeNarrative {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Descriptive only — never a credit/lending score. See lib/prompts/income-narrative.ts.
  narrative              String
  stabilityRating        String
  trendDirection         String
  diversificationSummary String
  notableObservations    String[]

  // sha256 of the sorted `slug:verifiedAmount` pairs used to generate this row — see
  // lib/ai/income-narrative.ts's computeInputHash. Changes whenever a connection is added,
  // removed, or its verifiedAmount changes.
  inputHash   String
  generatedAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)
}

enum ReportJobStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

// Tracks an async PDF-report render so app/api/report/route.tsx never blocks a request/
// serverless invocation on `renderToBuffer` (see README's "Where new work goes" section) — the
// POST route creates this row and schedules the render via Next.js's `after()`, and
// app/api/report/[jobId]/route.ts polls it. `pdfData` is stored inline (Postgres bytea) rather
// than in object storage: report sizes here are small (a text/table PDF, no images) and this
// avoids adding a new storage dependency for a foundational-scale fix — revisit if report
// size/volume ever makes that impractical. `expiresAt` rows are opportunistically deleted by the
// next job creation for the same user (see lib/report-jobs.ts) rather than a cron job, the same
// "cheap inline cleanup, no scheduler" precedent lib/rate-limit.ts already uses.
model ReportJob {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         ReportJobStatus @default(PENDING)
  // Raw `platforms` query param from the request that created this job, re-applied by the after()
  // callback so the rendered subset always matches what the caller asked for.
  platformsParam String?
  pdfData        Bytes?
  filename       String?
  error          String?
  createdAt      DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime        @updatedAt @db.Timestamptz(3)
  expiresAt      DateTime        @db.Timestamptz(3)

  @@index([userId])
}
