// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Prisma 7 removed `url`/`directUrl` from the schema file — connection URLs now
  // live in prisma.config.ts (for the CLI/migration engine) and are passed directly
  // to the driver adapter in lib/db.ts (for the app's runtime client). See:
  // https://pris.ly/d/config-datasource
}

model User {
  id        String    @id @default(cuid())
  clerkId   String    @unique
  email     String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  subscription        Subscription?
  platformConnections PlatformConnection[]
  incomeNarrative     IncomeNarrative?

  @@index([clerkId])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus @default(INCOMPLETE)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([stripeCustomerId])
}

enum SubscriptionStatus {
  INCOMPLETE
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  TRIALING
}

// A signed-in user's connection to one mocked income platform (see
// components/landing/platform-data.ts, the source of truth for valid slugs and each platform's
// demo verifiedAmount). One row per connected platform per user — reconnecting the same platform
// upserts this row rather than creating a duplicate.
model PlatformConnection {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug           String
  verifiedAmount Decimal  @db.Decimal(10, 2)
  connectedAt    DateTime @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @db.Timestamptz(3)

  @@unique([userId, slug])
}

// Cached AI-generated (Gemini) descriptive summary of a user's verified income — see
// lib/ai/income-narrative.ts. One row per user. Regenerated when `inputHash` (a hash of the
// user's current per-platform verifiedAmounts) no longer matches the latest connection state, or
// when `generatedAt` is older than the service's staleness window — whichever comes first. This
// exists purely so the dashboard card and the PDF report don't call Gemini on every single page
// load/report download; it is never treated as a source of truth for verifiedAmount itself.
model IncomeNarrative {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Descriptive only — never a credit/lending score. See lib/prompts/income-narrative.ts.
  narrative              String
  stabilityRating        String
  trendDirection         String
  diversificationSummary String
  notableObservations    String[]

  // sha256 of the sorted `slug:verifiedAmount` pairs used to generate this row — see
  // lib/ai/income-narrative.ts's computeInputHash. Changes whenever a connection is added,
  // removed, or its verifiedAmount changes.
  inputHash   String
  generatedAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)
}
