# Dependencies (reinstalled fresh in the `deps` build stage)
node_modules

# Build output (regenerated by `npm run build` in the `builder` stage)
.next
out
lib/generated

# Env files — never send local/real secrets into the build context.
# Build-time NEXT_PUBLIC_* values are passed explicitly via --build-arg
# instead, per docker-compose.yml.
.env
.env.local
.env.*
!.env.example

# Other secret/credential file shapes — belt-and-suspenders alongside the
# .env rules above, mirroring the root .gitignore's equivalent list.
*.pem
*.key
*.p12
*.pfx
*.crt
*credentials*.json
*service-account*.json

# Compose local overrides (shouldn't exist inside this build context, but
# never send one into the image if it does)
docker-compose.override.yml
docker-compose.override.yaml

# Version control / editor / OS
.git
.gitignore
.vscode
.idea
.DS_Store

# Test artifacts
/coverage
/test-results
/playwright-report
/blob-report
/playwright/.cache
e2e

# Clerk local config (may include secrets)
.clerk

# Vercel local project/deployment config (may include tokens)
.vercel

# Turbopack persistent cache
.turbo

# Misc local/build artifacts
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Docs and agent/skill scaffolding not needed inside the image
README.md
AGENTS.md
CLAUDE.md
.agents

# Docker files themselves
Dockerfile
.dockerignore
