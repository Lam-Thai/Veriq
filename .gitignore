# OS / editor
.DS_Store
.vscode/
.idea/

# Python (backend/)
backend/.venv/
backend/__pycache__/
backend/**/__pycache__/
backend/.mypy_cache/
backend/.ruff_cache/
backend/.pytest_cache/
backend/*.egg-info/
backend/.env

# secrets / credentials — never commit these
*.pem
*.key
*.p12
*.pfx
*.crt
*credentials*.json
*service-account*.json

# env files at any depth (root .env, frontend/.env.local, backend/.env, etc.) —
# these hold real API keys (Clerk, GitGuardian, ...); only .env.example variants are safe to commit
.env
.env.*
!.env.example
!.env.*.example

# postgres.env doesn't match the `.env`/`.env.*` wildcard above (no leading
# dot) since docker-compose.yml's optional postgres service names it that
# way to keep it out of Compose's implicit root-.env auto-loading.
postgres.env
!postgres.env.example

# belt-and-suspenders: name the files this repo actually uses today, in case the
# wildcard rule above is ever narrowed or removed without someone re-checking this list
/.env
/frontend/.env.local
/backend/.env

# Docker Compose local overrides — Compose auto-loads these on top of
# docker-compose.yml, so they're a common place to stash ad-hoc local
# secrets, personal port/volume tweaks, etc. Keep them machine-local.
docker-compose.override.yml
docker-compose.override.yaml
docker-compose.*.local.yml
docker-compose.*.local.yaml
