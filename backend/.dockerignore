# Virtual env / caches (reinstalled fresh in the `builder` stage)
.venv
__pycache__
**/__pycache__
*.pyc
.mypy_cache
.ruff_cache
.pytest_cache
*.egg-info

# Env files — never send local/real secrets into the build context.
.env
.env.*
!.env.example

# Other secret/credential file shapes — belt-and-suspenders alongside the
# .env rules above, mirroring the root .gitignore's equivalent list.
*.pem
*.key
*.p12
*.pfx
*.crt
*credentials*.json
*service-account*.json

# Compose local overrides (shouldn't exist inside this build context, but
# never send one into the image if it does)
docker-compose.override.yml
docker-compose.override.yaml

# Version control / editor / OS
.git
.gitignore
.vscode
.idea
.DS_Store

# Tests (not needed in the runtime image; pytest runs natively / in CI)
tests

# Docs and Docker files themselves
README.md
Dockerfile
.dockerignore
