ENVIRONMENT=development
ALLOWED_ORIGINS=["http://localhost:3000"]

# Shared secret for verifying the short-lived service-token JWT Next.js sends on internal calls
# (app/auth.py). Must match frontend/.env.local's INTERNAL_JWT_SECRET exactly.
INTERNAL_JWT_SECRET=

# Sentry DSN (https://sentry.io) for error tracking/APM — optional, the SDK no-ops when unset.
SENTRY_DSN=
