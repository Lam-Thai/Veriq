# Used only by `docker compose build` (see docker-compose.yml → frontend.build.args).
#
# Next.js inlines NEXT_PUBLIC_* variables into the client bundle at build
# time, so docker-compose needs them at `docker compose build`/`up --build`
# time, sourced from this root .env file (Compose auto-loads a root .env for
# variable interpolation). These are the same public, non-secret values
# already in frontend/.env.local — copy them over from there.
#
# This file is NOT read by `npm run dev` or `next build` directly; it exists
# solely so docker-compose can pass build args without hardcoding values in
# docker-compose.yml. All other configuration (including server-only
# secrets like CLERK_SECRET_KEY) continues to come from backend/.env and
# frontend/.env.local at container runtime — see README.md.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Optional — only needed if you use non-default Clerk routes; otherwise the
# defaults baked into docker-compose.yml (/sign-in, /sign-up, /dashboard)
# apply automatically.
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
# NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/dashboard

# The optional `postgres` Compose profile has its own env file —
# see postgres.env.example, not this one.
