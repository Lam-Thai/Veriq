# Used only by the optional `postgres` service in docker-compose.yml
# (docker compose --profile postgres up), reserved for the currently-paused
# Prisma/PostgreSQL persistence effort.
#
# cp postgres.env.example postgres.env, then fill in your own local values —
# postgres.env is git-ignored, same as backend/.env and frontend/.env.local.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
