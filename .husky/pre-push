#!/usr/bin/env sh
# Runs the repo's test suite before allowing a push. Blocks the push
# (non-zero exit) if backend pytest or the frontend checks fail.
#
# Only invokes locally installed, version-controlled tooling — never
# fetches or executes remote scripts.
#
# To run the same checks manually: sh .husky/pre-push

repo_root=$(cd "$(dirname "$0")/.." && pwd)
backend_dir="$repo_root/backend"
frontend_dir="$repo_root/frontend"

# Ceiling per check — a hung pytest/lint/build shouldn't block a push indefinitely.
check_timeout_secs=300

# Runs "$@" in $1, bounded by check_timeout_secs when the `timeout` binary is
# available (falls back to running unbounded, e.g. on a bare macOS without
# coreutils, rather than failing the hook outright).
run_checked() {
  label="$1"
  dir="$2"
  shift 2
  if command -v timeout >/dev/null 2>&1; then
    (cd "$dir" && timeout "$check_timeout_secs" "$@")
  else
    (cd "$dir" && "$@")
  fi
  status=$?
  if [ "$status" -eq 124 ]; then
    echo "pre-push: $label timed out after ${check_timeout_secs}s." >&2
  fi
  return "$status"
}

echo "pre-push: running backend test suite (pytest)..."

if [ -x "$backend_dir/.venv/Scripts/python.exe" ]; then
  python_bin="$backend_dir/.venv/Scripts/python.exe"
elif [ -x "$backend_dir/.venv/bin/python" ]; then
  python_bin="$backend_dir/.venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
  echo "pre-push: backend/.venv not found, falling back to 'python3' on PATH." >&2
  python_bin="python3"
else
  echo "pre-push: backend/.venv not found, falling back to 'python' on PATH." >&2
  python_bin="python"
fi

if ! run_checked "backend pytest" "$backend_dir" "$python_bin" -m pytest -q; then
  echo "pre-push: backend pytest failed (or backend/.venv is missing)." >&2
  echo "pre-push: set it up with: cd backend && python -m venv .venv && pip install -e \".[dev]\"" >&2
  exit 1
fi

echo "pre-push: running frontend checks (lint, unit tests, build)..."

if ! run_checked "frontend lint" "$frontend_dir" npm run lint; then
  echo "pre-push: frontend lint failed." >&2
  exit 1
fi

if ! run_checked "frontend unit tests" "$frontend_dir" npm run test; then
  echo "pre-push: frontend unit tests (vitest) failed." >&2
  exit 1
fi

if ! run_checked "frontend build" "$frontend_dir" npm run build; then
  echo "pre-push: frontend build failed." >&2
  exit 1
fi

echo "pre-push: all checks passed."
